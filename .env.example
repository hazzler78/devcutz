# Kopiera till `.env.local` för lokal utveckling (filen committas INTE).
# På Vercel: Settings → Environment Variables → lägg till samma nyckel för Production (och Preview om du vill).

# --- Instagram-widget (@devvcuts) ------------------------------------------
# Klistra in **iframe-URL:en** från din widget (LightWidget, EmbedSocial, Elfsight …).
# Måste börja med https://
#
# Exempel LightWidget:
# NEXT_PUBLIC_INSTAGRAM_WIDGET_URL=https://cdn.lightwidget.com/widgets/ditt-id.html
#
NEXT_PUBLIC_INSTAGRAM_WIDGET_URL=
